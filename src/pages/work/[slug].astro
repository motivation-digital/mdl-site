---
// LCE-10000383 — mdl-site case study pages
// Statically pre-rendered from the shared caseStudy() render function
// All 11 case study slugs are pre-rendered at build time

import { PROJECTS, caseStudy } from "../../lib/render-case-study.js";
import { SLUGS } from "../../lib/portfolio.js";

export function getStaticPaths() {
  return SLUGS.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
const project = PROJECTS[slug];

if (!project) {
  return Astro.redirect('/work');
}

const html = caseStudy(project, slug);
---
<Fragment set:html={html} />
